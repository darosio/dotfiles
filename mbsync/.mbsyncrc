# Save the synchronization state files in the relevant directory
SyncState *

# Automatically create missing mailboxes, both locally and on the server
Create Both  # default None
Remove Near
# Set off auto-expunge deleted messages on gmail IMAP server configuration:
# https://mail.google.com/mail/u/0/?tab=cm#settings/fwdandpop
Expunge Both
CopyArrivalDate yes

################################################################################
# CNR (Office 365)
################################################################################
IMAPAccount cnr
Host outlook.office365.com
Port 993
User daniele.arosio@cnr.it
PassCmd "~/.local/bin/mutt_oauth2.py ~/.config/mutt_oauth2/cnr.tokens"
AuthMechs XOAUTH2
TLSType IMAPS
CertificateFile /etc/ssl/certs/ca-certificates.crt

IMAPStore cnr-remote
Account cnr

MaildirStore cnr-local
SubFolders Verbatim
Path ~/Maildir/cnr/
Inbox ~/Maildir/cnr/INBOX

Channel cnr
Far :cnr-remote:
Near :cnr-local:
Patterns INBOX "Sent Items" Drafts "Deleted Items" "Junk Email" Trash Outbox


################################################################################
# Postecert
################################################################################
# imap account information
IMAPAccount pec
Host mail.postecert.it
User daniele.arosio@postecert.it
PassCmd "pass email/postecert"
TLSType IMAPS
CertificateFile /etc/ssl/certs/ca-certificates.crt

# remote storage (use the imap account specified above)
IMAPStore pec-remote
Account pec

# local storage
MaildirStore pec-local
# The trailing "/" is important
Path ~/Maildir/pec/
Inbox ~/Maildir/pec/INBOX

# channel to remote storage
Channel pec
Far :pec-remote:
Near :pec-local:
Patterns INBOX *

################################################################################
# Gmail for dpa
################################################################################
# imap account information
IMAPAccount gmail
Host imap.gmail.com
User danielepietroarosio@gmail.com
PassCmd "pass email/gmail-mbsync"
TLSType IMAPS
CertificateFile /etc/ssl/certs/ca-certificates.crt

# remote storage (use the imap account specified above)
IMAPStore gmail-remote
Account gmail

# local storage
MaildirStore gmail-local
SubFolders Verbatim
Path ~/Maildir/gmail/
Inbox ~/Maildir/gmail/Inbox

# channel to remote storage
Channel gmail
Far :gmail-remote:
Near :gmail-local:
Patterns * ![Gmail]* "[Gmail]/Drafts" "[Gmail]/Sent Mail" "[Gmail]/Spam" "[Gmail]/Trash"

# Group gmail
