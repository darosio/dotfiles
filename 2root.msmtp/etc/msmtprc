# System-wide msmtp configuration

# Default settings
defaults
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        /var/log/msmtp.log
aliases        /etc/msmtp.aliases

account        default
host           smtp.googlemail.com
port           587
auth           on
from           danielepietroarosio@gmail.com
user           danielepietroarosio@gmail.com
passwordeval   "sh -c 'if [ -f /home/dan/.msmtp-gmail-pass ]; then cat /home/dan/.msmtp-gmail-pass; else sudo -u dan PASSWORD_STORE_DIR=/home/dan/Sync/.pass/ pass email/gmail-isync; fi'"
