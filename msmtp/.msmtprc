# Example for a user configuration file

# Set default values for all following accounts.
defaults
aliases			/home/dan/.msmtp.aliases
logfile			~/.msmtp.log
tls				on
tls_trust_file	/etc/ssl/certs/ca-certificates.crt
#tls_starttls	off

#
# gmail
account			gmail
host			smtp.googlemail.com
port			587
auth			on
from			danielepietroarosio@gmail.com
user			danielepietroarosio@gmail.com
passwordeval    "sh -c 'if [ -f /home/dan/.msmtp-gmail-pass ]; then cat /home/dan/.msmtp-gmail-pass; else pass email/gmail-isync; fi'"



# postecert
account			pec
host			mail.postecert.it
port			465
auth			on
tls				on
tls_starttls	off
from			daniele.arosio@postecert.it
user			daniele.arosio@postecert.it
passwordeval	"pass email/postecert"

# Cnr (Office 365)
account			cnr
host			smtp.office365.com
port			587
auth			on
tls			on
tls_starttls		on
from			daniele.arosio@cnr.it
user			daniele.arosio@cnr.it
passwordeval		"pass email/cnr"

# Yahoo
account			yahoo
host			smtp.mail.yahoo.com
from			danielearosio@yahoo.it
user			danielearosio@yahoo.it
passwordeval	"pass email/yahoo"
#passwordeval	"pass email/yahoo | awk 'BEGIN{getline; print $0}'"

# Set a default account
account default : gmail
